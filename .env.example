# BBSolana - Environment Variables Template
# Copy this file to .env and fill in your values

# ====================
# Database Configuration
# ====================
POSTGRES_PASSWORD=your_secure_password_here
DATABASE_URL=postgresql://bbsolana:${POSTGRES_PASSWORD}@postgres:5432/bbsolana

# ====================
# Redis Configuration
# ====================
REDIS_URL=redis://redis:6379/0

# ====================
# Security Configuration
# ====================
SECRET_KEY=your-secret-key-change-in-production
ENCRYPTION_KEY=your-32-byte-base64-encoded-encryption-key

# ====================
# CORS Configuration
# ====================
CORS_ORIGINS=http://localhost:3000,http://frontend:3000

# ====================
# Debug & Development
# ====================
DEBUG=true

# ====================
# Frontend Configuration
# ====================
NEXT_PUBLIC_API_URL=http://localhost:8000/api/v1
NEXT_PUBLIC_WS_URL=ws://localhost:8000/ws

# ====================
# Exchange API Keys (Development Only)
# ====================
# CoinSpot
COINSPOT_API_KEY=your_coinspot_api_key
COINSPOT_SECRET=your_coinspot_secret

# Binance
BINANCE_API_KEY=your_binance_api_key
BINANCE_SECRET=your_binance_secret

# Kraken
KRAKEN_API_KEY=your_kraken_api_key
KRAKEN_PRIVATE_KEY=your_kraken_private_key

# ====================
# AI Model Configuration
# ====================
KRONOS_MODEL=NeoQuasar/Kronos-small
KRONOS_TOKENIZER=NeoQuasar/Kronos-Tokenizer-base
KRONOS_DEVICE=cpu  # or cuda if GPU available

# ====================
# Celery Configuration
# ====================
CELERY_BROKER_URL=redis://redis:6379/0
CELERY_RESULT_BACKEND=redis://redis:6379/0

# ====================
# Email Configuration (Optional)
# ====================
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your_email@gmail.com
SMTP_PASSWORD=your_app_password
EMAIL_FROM=noreply@bbsolana.local